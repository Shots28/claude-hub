# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://wnyfhhvapljyzrwvxpek.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
# Auto-generated and persisted to data/.jwt-secret if not set
JWT_SECRET=

# Instance management
MAX_CONCURRENT_QUERIES=3
IDLE_TIMEOUT_MINUTES=30

# Server
PORT=3100
SHUTDOWN_TIMEOUT_MS=30000
STREAMING_DEBOUNCE_CHARS=50

# Optional features
# OPENAI_API_KEY=           # For voice transcription via Whisper
# MCP_PLAN_REVIEW_PATH=     # Path to plan-review MCP server (skipped if not found)

# Push Notifications (Phase 2)
# Generate VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
PUSH_API_SECRET=            # High-entropy secret shared between bridge and Vercel
APP_URL=http://localhost:3100  # Vercel deployment URL (or localhost for dev)
